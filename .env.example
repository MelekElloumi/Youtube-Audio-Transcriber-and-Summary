# YouTube Transcriber — Environment Variables
# Copy this file to .env and fill in your values

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Notion API
NOTION_TOKEN=your_notion_token_here
NOTION_PARENT_PAGE_ID=your_notion_parent_page_id_here

# yt-dlp path (optional — defaults to "yt-dlp" on system PATH)
# YTDLP_PATH=yt-dlp

# Test mode: caps transcript to 1000 chars, audio to 5 min
TEST_MODE=false
